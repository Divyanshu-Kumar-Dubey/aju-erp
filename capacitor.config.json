{
  "appId": "com.aju.erp",
  "appName": "AJU ERP",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#1a237e"
  },
  "plugins": {
